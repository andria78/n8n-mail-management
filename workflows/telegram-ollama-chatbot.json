    {
      "parameters": {
        "promptType": "define",
        "text": "={{ \"Chat ID: \" + $('Telegram Message Received').item.json.message.chat.id + \"\\nCurrent date: \" + $now.setZone('Europe/Paris').toFormat('yyyy-MM-dd') + \" (Europe/Paris).\\nPre-computed date filters for Read OVH Emails:\\n- last 7 days  -> since=\" + $now.setZone('Europe/Paris').minus({days:7}).toFormat('yyyy-MM-dd') + \"\\n- last 14 days -> since=\" + $now.setZone('Europe/Paris').minus({days:14}).toFormat('yyyy-MM-dd') + \"\\n- last 30 days -> since=\" + $now.setZone('Europe/Paris').minus({days:30}).toFormat('yyyy-MM-dd') + \"\\n- today only   -> since=\" + $now.setZone('Europe/Paris').toFormat('yyyy-MM-dd') + \"\\n\\n\" + ($json.message.text || \"\") }}",
        "options": {
          "systemMessage": "You are a helpful Telegram assistant with access to OVH Outlook emails via the \"Read OVH Emails\" tool.\n\nDATE HANDLING (CRITICAL):\n- The current date and pre-computed date filters are at the top of the user message. Use them directly. NEVER ask the user for dates.\n\nOUTPUT RULES:\n- Always report the total count of emails found.\n- By default show up to 10 most recent emails with a summary of total count.\n- If the user asks to see more, list ALL returned emails.\n- Respond in the same language the user writes in.\n- Use plain text only - no markdown, HTML, or special formatting.\n- NEVER invent email data. Only report what the tool actually returns.",
          "enableStreaming": false
        }
      },
      "id": "c42909c3-ac7e-4061-8fa8-1d5a78900b12",
      "name": "AI Assistant with Email",
