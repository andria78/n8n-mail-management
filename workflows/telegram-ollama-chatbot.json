      "id": "b7fa2fe2-ce27-47f6-956c-667adf1dd6cf",
      "name": "Read OVH Emails",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 2.2,
      "position": [
        2480,
        48
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const output = $json.output || '';\nconst MAX = 3900;\nconst entries = output.split(/\\n\\n+/);\nconst chunks = [];\nlet current = '';\nfor (const entry of entries) {\n  const candidate = current ? current + '\\n\\n' + entry : entry;\n  if (candidate.length > MAX && current.length > 0) {\n    chunks.push(current);\n    current = entry;\n  } else {\n    current = candidate;\n  }\n}\nif (current) chunks.push(current);\nreturn chunks.map((c, idx) => ({ json: { output: c, chunkIndex: idx, chunkTotal: chunks.length } }));"
      },
      "id": "fba75fec-71bc-4cd4-a159-9a7b53595d1d",
      "name": "Split Long Reply",
